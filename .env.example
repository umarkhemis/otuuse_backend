# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=Otuuse Transport API
APP_ENV=development          # production on Render
APP_DEBUG=true               # false on Render

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-min-32-chars-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT=30

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local:   redis://localhost:6379/0
# Upstash: rediss://default:password@host.upstash.io:6379
REDIS_URL=redis://localhost:6379/0
REDIS_DRIVER_LOCATION_TTL=30
REDIS_SESSION_TTL=86400

# ── Firebase ──────────────────────────────────────────────────────────────────
# Local dev: path to service account JSON file
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json
# Production (Render): paste the entire JSON file content as a single line
# FIREBASE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}

# ── PesaPal ───────────────────────────────────────────────────────────────────
# Sandbox: https://cybqa.pesapal.com/pesapalv3
# Live:    https://pay.pesapal.com/v3
PESAPAL_BASE_URL=https://cybqa.pesapal.com/pesapalv3
PESAPAL_CONSUMER_KEY=your-consumer-key
PESAPAL_CONSUMER_SECRET=your-consumer-secret
# Set these AFTER you have a public URL (after Render deployment):
PESAPAL_IPN_URL=https://your-render-domain.onrender.com/api/v1/payments/pesapal-ipn
PESAPAL_CALLBACK_URL=https://your-render-domain.onrender.com/api/v1/payments/callback

# ── OpenRouteService ──────────────────────────────────────────────────────────
ORS_BASE_URL=https://api.openrouteservice.org/v2
ORS_API_KEY=your-ors-api-key

# ── Groq (AI agent) ───────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key

# ── Dispatch ──────────────────────────────────────────────────────────────────
DISPATCH_MAX_DRIVER_SEARCH_RADIUS_KM=5
DISPATCH_DRIVER_ACCEPTANCE_TIMEOUT_SECONDS=30
